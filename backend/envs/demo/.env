# Backend settings for demo environment

# Database file
BACKEND_DB_FILE=./envs/demo/db.sqlite

# Environment mode
BACKEND_ENVIRONMENT=demo

# Auth server URL (Go auth server)
BACKEND_AUTH_SERVER_URL=http://localhost:12870

# Auth command URL (management commands on 127.0.0.2)
BACKEND_AUTH_COMMAND_URL=http://127.0.0.2:12871

# Frontend origin for CORS
BACKEND_FRONTEND_ORIGIN=https://demo.dsavdodeka.nl

# Enable debug logging
BACKEND_DEBUG_LOGS=true

# Server port (public API)
BACKEND_PORT=12880

# Private server port (Go-Python communication)
BACKEND_PRIVATE_PORT=12890

# SMTP configuration
# BACKEND_SMTP_HOST=
# BACKEND_SMTP_PORT=587
# BACKEND_SMTP_SENDER_EMAIL=bestuur@dsavdodeka.nl
# BACKEND_SMTP_SENDER_NAME=D.S.A.V. Dodeka
# BACKEND_SMTP_USERNAME=
# BACKEND_SMTP_PASSWORD=

# Set to true to actually send emails via SMTP
# When false (default), emails are saved to the emails/ directory
# BACKEND_SMTP_SEND=false
